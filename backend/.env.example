# Copy this file to .env and adjust as needed.

PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=neostore_lab

# VULN(broken-authentication): weak, guessable, hardcoded-style secret.
# In a real app this must be a long random value pulled from a secrets manager.
JWT_SECRET=neostore_secret_123

# VULN(broken-authentication): tokens live for 7 days with no refresh/rotation
# and the server never checks a revocation list, so a stolen token works for
# a full week even after "logout".
JWT_EXPIRES_IN=7d
